# Variabel frontend yang aman digunakan oleh aplikasi peserta.
# Appwrite media sudah punya default bawaan di kode; isi nilai ini hanya kalau ingin override deployment tertentu.
# `mock` adalah mode bawaan yang aktif.
# `api` hanya kontrak future-proof dan tetap membutuhkan route backend `/api/feed`.
VITE_FEED_SOURCE=mock
VITE_APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=69f22cb20001f8be28b3
VITE_APPWRITE_BUCKET_ID=69f2b4dd002f17ed5c64
VITE_CLOUDFLARE_STREAM_CUSTOMER_CODE=
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Variabel privat untuk skrip admin lokal / tooling server-side.
# JANGAN pernah mengekspos nilai ini ke browser atau meng-commit-nya ke git.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
